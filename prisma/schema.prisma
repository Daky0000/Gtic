// ─────────────────────────── Short courses ────────────────────────────
// The Center's real vocational training sessions — 2 to 8-week intensives
// run in scheduled batches. Registration is open to any signed-in account;
// the intake form mirrors the Center's paper application (Renewable Energy
// Training Application Form 2026) section for section. Payment reuses the
// invoice/payment machinery (kind SHORT_COURSE). A fee of 0 means "fee to
// be announced" — registration stays closed until the developer prices the
// course on the fees console.

model ShortCourse {
  id            String  @id @default(cuid())
  code          String  @unique
  name          String
  description   String
  audience      String // "Designed for: …" line from the published copy
  durationWeeks Int
  feePesewas    Int     @default(0)
  active        Boolean @default(true)

  batches       ShortCourseBatch[]
  registrations ShortCourseRegistration[]
}

/**
 * A scheduled intake — "Batch A/B/C" on the paper form. Batches share
 * start dates across courses; each batch's end date is its course's own
 * duration added to that start, so a 2-week and an 8-week course can share
 * the same intake calendar.
 */
model ShortCourseBatch {
  id            String      @id @default(cuid())
  shortCourseId String
  shortCourse   ShortCourse @relation(fields: [shortCourseId], references: [id], onDelete: Cascade)
  label         String // "Batch A"
  startDate     DateTime
  endDate       DateTime
  active        Boolean     @default(true)

  registrations ShortCourseRegistration[]

  @@unique([shortCourseId, label])
}

enum ShortCourseRegStatus {
  DRAFT
  SUBMITTED // awaiting the office's review (FOR OFFICE USE ONLY: Admission Status)
  WAITLISTED
  PENDING_PAYMENT // approved — the invoice is raised and awaiting the course fee
  CONFIRMED
  REJECTED
  CANCELLED
}

enum TshirtSize {
  S
  M
  L
  XL
  XXL
}

enum AccommodationChoice {
  YES
  NO
  NOT_SURE
}

enum EducationLevel {
  WASSCE
  DIPLOMA
  HND
  DEGREE
  OTHER
}

enum ExperienceLevel {
  NONE
  MONTHS_0_6
  MONTHS_6_24
  YEARS_2_PLUS
}

enum SponsorshipType {
  SELF
  COMPANY
  NGO
}

enum ReferralSource {
  FACEBOOK
  WHATSAPP
  FRIEND
  RADIO
  ECG
  OTHER
}

// Mirrors the paper form's Sections A–E plus its "FOR OFFICE USE ONLY" strip.
// Editable only while DRAFT; the registration reference ("Form Code" on the
// paper form) is assigned when the applicant submits for review. Submitting
// does NOT raise an invoice — the office reviews the form first (Admission
// Status: Approved/Waitlisted/Rejected); approval is what raises the invoice
// and moves the registration to PENDING_PAYMENT, exactly like the paper
// form's "Payment Confirmed" line follows its "Admission Status" line.
model ShortCourseRegistration {
  id            String               @id @default(cuid())
  refNo         String?              @unique
  shortCourseId String
  shortCourse   ShortCourse          @relation(fields: [shortCourseId], references: [id])
  batchId       String?
  batch         ShortCourseBatch?    @relation(fields: [batchId], references: [id])
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        ShortCourseRegStatus @default(DRAFT)
  invoiceId     String?
  createdAt     DateTime             @default(now())
  submittedAt   DateTime? // applicant submitted for review
  decidedAt     DateTime? // office recorded an admission decision
  decisionNote  String? // reason shown to the applicant on waitlist/reject
  confirmedAt   DateTime?

  // Section A — personal details
  fullName              String?
  gender                String?
  dateOfBirth           DateTime?
  idNumber              String? // Ghana Card / Passport number
  phone                 String?
  email                 String? // contact email on the form (defaults to the account email)
  currentAddress        String? // "Where are you currently staying?"
  homeRegion            String? // "Home region / where coming from"
  emergencyName         String?
  emergencyRelationship String?
  emergencyPhone        String?
  emergencyEmail        String?

  // Section B — training details
  fullDuration        Boolean?
  partialDurationNote String?
  accommodation       AccommodationChoice?
  tshirtSize          TshirtSize?

  // Section C — education & experience
  educationLevel  EducationLevel?
  educationOther  String?
  experienceLevel ExperienceLevel?
  experienceNote  String?
  toolsOwned      String[]         @default([])

  // Section D — medical & safety
  medicalConditions String?
  bloodGroup        String?

  // Section E — referral, sponsorship & declaration
  referralSource      ReferralSource?
  referralOther       String?
  sponsorship         SponsorshipType?
  sponsorName         String?
  declarationName     String? // typed signature
  declarationAccepted Boolean          @default(false)
  declarationSignedAt DateTime?

  documents ShortCourseDocument[]

  @@unique([shortCourseId, userId])
  @@index([shortCourseId, status])
}

enum ShortCourseDocKind {
  CV
  CERTIFICATE
  PHOTO
  ID_DOCUMENT
  OTHER
}

model ShortCourseDocument {
  id             String                  @id @default(cuid())
  registrationId String
  registration   ShortCourseRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  kind           ShortCourseDocKind
  fileName       String
  filePath       String
  mimeType       String
  size           Int
  uploadedAt     DateTime                @default(now())

  @@index([registrationId])
}

// ─────────────────────────── Form builder ─────────────────────────────
// Admin/developer-built forms (surveys, feedback, data collection) with a
// public fill link and response/results views in the console. Field
// definitions live as JSON [{id, label, type, required, options[]}] —
// relational integrity is not needed for v1 and JSON keeps editing simple.

enum FormStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum FormType {
  GENERIC
  ADMISSION
}

// Where a form's entry point appears. LINK_ONLY: reachable only via its
// /forms/<slug> link. PUBLIC_NAV: a link in the public site header/footer.
// APPLICANT_PORTAL: a link inside the applicant portal.
enum FormPlacement {
  LINK_ONLY
  PUBLIC_NAV
  APPLICANT_PORTAL
}

// A payment-first applicant registration held BEFORE any account exists.
// Signup captures details + a pre-hashed password here and starts checkout;
// the account, applicant role and draft application are created only when
// the payment confirms (see completePendingRegistration). Serial + PIN are
// the applicant's proof of purchase (delivered by SMS, verifiable by staff).
enum PendingRegStatus {
  PENDING
  COMPLETED
  EXPIRED
}

model PendingRegistration {
  id           String           @id @default(cuid())
  name         String
  email        String
  phone        String
  passwordHash String
  cycleId      String
  amount       Int
  reference    String           @unique
  serial       String           @unique
  pin          String
  status       PendingRegStatus @default(PENDING)
  userId       String? // set when completed
  createdAt    DateTime         @default(now())
  completedAt  DateTime?

  @@index([email])
  @@index([status])
}

model FormDef {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?
  status      FormStatus    @default(DRAFT)
  // GENERIC = ordinary survey/data form; ADMISSION = the special admission
  // application (keeps the programme picker, AI results upload, fee gating).
  type        FormType      @default(GENERIC)
  // Where the form (or its entry point) is surfaced.
  placement   FormPlacement @default(LINK_ONLY)
  fields      Json          @default("[]")
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  responses FormResponse[]
}

model FormResponse {
  id              String   @id @default(cuid())
  formId          String
  form            FormDef  @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  respondentName  String?
  respondentEmail String?
  answers         Json
  submittedAt     DateTime @default(now())

  @@index([formId, submittedAt])
}
