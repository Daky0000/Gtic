// CampusCore — Phase 0 schema: identity & access, institution config,
// academic structure (demo scope), audit, notifications, AI core.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identity & access ───────────────────────────
// User/Session/Account/Verification follow better-auth's required shape.

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions        Session[]
  accounts        Account[]
  roleAssignments RoleAssignment[]
  notifications   Notification[]
  aiConversations AIConversation[]

  // Domain links (phases 1+)
  applications     Application[]
  student          Student?
  staffProfile     StaffProfile?
  invoices         Invoice[]
  documentRequests DocumentRequest[]
  loans            Loan[]
  leaveRequests    LeaveRequest[]
  taughtOfferings  OfferingLecturer[]

  shortCourseRegistrations ShortCourseRegistration[]
  formResponses            FormResponse[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ───────────────────────────────── RBAC ──────────────────────────────────

model Role {
  id          String  @id @default(cuid())
  code        String  @unique // e.g. "student", "registrar", "system_admin"
  name        String
  description String?

  permissions RolePermission[]
  assignments RoleAssignment[]
}

model Permission {
  id     String @id @default(cuid())
  code   String @unique // e.g. "admissions.review", "results.publish"
  name   String
  module String // owning module, e.g. "admissions"

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RoleAssignment {
  id            String    @id @default(cuid())
  userId        String
  roleId        String
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime? // null = open-ended
  assignedById  String?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleId])
}

// ─────────────────────── Institution (white-label) ───────────────────────

model Institution {
  id             String  @id @default(cuid())
  name           String
  shortName      String
  motto          String?
  primaryColor   String  @default("#166534")
  secondaryColor String  @default("#14532d")
  logoUrl        String?
  address        String?
  contactEmail   String?
  contactPhone   String?
  website        String?

  updatedAt DateTime @updatedAt
}

// Key-value system configuration managed from the developer console.
// Values override environment variables at runtime (secrets included) —
// integration keys, configurable fees, feature switches.
model SystemSetting {
  key         String   @id
  value       String
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// Developer-controlled visibility of portals and portal menu items. A row's
// presence means that key is hidden; deleting it restores the default
// (visible). Keys are "portal:<portal>" or "nav:<href>" — see src/lib/feature-flags.ts.
model FeatureFlag {
  key         String   @id
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// ───────────────────── Academic structure (demo scope) ───────────────────

enum ProgrammeLevel {
  UNDERGRADUATE
  POSTGRADUATE
  DIPLOMA
}

model School {
  id   String @id @default(cuid())
  code String @unique
  name String

  departments Department[]
}

model Department {
  id       String @id @default(cuid())
  code     String @unique
  name     String
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  programmes Programme[]
  courses    Course[]

  @@index([schoolId])
}

model Programme {
  id                String         @id @default(cuid())
  code              String         @unique
  name              String
  level             ProgrammeLevel @default(UNDERGRADUATE)
  durationSemesters Int            @default(8)
  departmentId      String
  department        Department     @relation(fields: [departmentId], references: [id])
  entryRequirements String? // plain-text summary shown in the catalogue (structured rules come in Phase 1)

  // Fixed annual intake (published calendar): applications for this programme
  // CLOSE on admissionCloses* and reopen once the cohort starts on
  // cohortStarts* (applying then targets next year's cohort). Null = always open.
  admissionClosesMonth Int? // 1-12
  admissionClosesDay   Int? // 1-31
  cohortStartsMonth    Int?
  cohortStartsDay      Int?

  cycleProgrammes    CycleProgramme[]
  applicationChoices ApplicationChoice[]
  offers             Offer[]
  students           Student[]
  curriculumVersions CurriculumVersion[]

  @@index([departmentId])
}

// ──────────────────────────────── Audit ──────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String? // null = system
  actorEmail String?
  action     String // e.g. "user.role_assigned", "knowledge.published"
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// ───────────────────────────── Notifications ─────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

// ──────────────────────────────── AI core ────────────────────────────────

enum DocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model KnowledgeDocument {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  category    String // e.g. "handbook", "exam-regulations", "fees", "admissions"
  version     Int            @default(1)
  status      DocumentStatus @default(DRAFT)
  sourceText  String // full original text
  publishedAt DateTime?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  chunks KnowledgeChunk[]
}

model KnowledgeChunk {
  id         String            @id @default(cuid())
  documentId String
  document   KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ord        Int
  heading    String?
  content    String

  @@index([documentId])
}

model AIFeatureConfig {
  id                 String  @id @default(cuid())
  feature            String  @unique // "assistant", "doc_extraction", "prescreen", ...
  enabled            Boolean @default(true)
  provider           String  @default("auto") // auto | anthropic | mock
  model              String  @default("claude-opus-4-8")
  effort             String  @default("high") // low | medium | high | xhigh | max
  monthlyTokenBudget Int? // null = unlimited
  systemPromptExtra  String?

  updatedAt DateTime @updatedAt
}

enum AIMessageRole {
  USER
  ASSISTANT
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   String   @default("assistant")
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AIMessage[]

  @@index([userId])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AIMessageRole
  content        String
  citations      Json? // [{documentSlug, documentTitle, heading}]
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

enum AIOutcome {
  OK
  ERROR
  REFUSAL
  BUDGET_BLOCKED
  DISABLED
}

model AIAuditLog {
  id              String    @id @default(cuid())
  userId          String?
  feature         String
  provider        String
  model           String
  inputTokens     Int       @default(0)
  outputTokens    Int       @default(0)
  cacheReadTokens Int       @default(0)
  latencyMs       Int       @default(0)
  outcome         AIOutcome
  error           String?
  createdAt       DateTime  @default(now())

  @@index([feature, createdAt])
  @@index([userId])
}

// ═══════════════════════ Phases 1–10 domain schema ═══════════════════════

// ─── Academic calendar ───

model AcademicYear {
  id        String   @id @default(cuid())
  label     String   @unique // "2026/2027"
  startsOn  DateTime
  endsOn    DateTime
  isCurrent Boolean  @default(false)

  semesters    Semester[]
  cycles       AdmissionCycle[]
  feeSchedules FeeSchedule[]
  students     Student[]
  bookings     Booking[]
}

model Semester {
  id             String       @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  number         Int // 1 or 2
  label          String // "2026/2027 Semester 1"
  startsOn       DateTime
  endsOn         DateTime
  isCurrent      Boolean      @default(false)

  windows       Window[]
  offerings     CourseOffering[]
  registrations Registration[]
  results       SemesterResult[]
  invoices      Invoice[]

  @@unique([academicYearId, number])
}

enum WindowType {
  REGISTRATION
  ADD_DROP
  HOSTEL_BOOKING
  EVALUATION
}

model Window {
  id         String     @id @default(cuid())
  semesterId String
  semester   Semester   @relation(fields: [semesterId], references: [id])
  type       WindowType
  opensAt    DateTime
  closesAt   DateTime

  @@unique([semesterId, type])
}

// ─── Admissions (Phase 1) ───

enum CycleStatus {
  OPEN
  CLOSED
}

model AdmissionCycle {
  id             String       @id @default(cuid())
  name           String
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  opensAt        DateTime
  closesAt       DateTime
  applicationFee Int // pesewas
  acceptanceFee  Int // pesewas
  status         CycleStatus  @default(OPEN)

  programmes   CycleProgramme[]
  applications Application[]
  vouchers     Voucher[]
}

model CycleProgramme {
  id          String         @id @default(cuid())
  cycleId     String
  cycle       AdmissionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  programmeId String
  programme   Programme      @relation(fields: [programmeId], references: [id])
  quota       Int?
  cutoffNote  String?

  @@unique([cycleId, programmeId])
}

enum VoucherStatus {
  GENERATED
  SOLD
  REDEEMED
}

model Voucher {
  id           String         @id @default(cuid())
  cycleId      String
  cycle        AdmissionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  serial       String         @unique
  pin          String
  status       VoucherStatus  @default(GENERATED)
  redeemedById String?
  redeemedAt   DateTime?
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  INFO_REQUESTED
  RECOMMENDED
  APPROVED
  WAITLISTED
  OFFER_ISSUED
  ACCEPTED
  DECLINED
  REJECTED
  ENROLLED
}

enum Recommendation {
  OFFER_FIRST_CHOICE
  OFFER_ALTERNATIVE
  WAITLIST
  REJECT
}

model Application {
  id      String            @id @default(cuid())
  refNo   String            @unique
  cycleId String
  cycle   AdmissionCycle    @relation(fields: [cycleId], references: [id])
  userId  String
  user    User              @relation(fields: [userId], references: [id])
  status  ApplicationStatus @default(DRAFT)

  // Personal details (snapshot at application time)
  surname        String?
  firstName      String?
  otherNames     String?
  dateOfBirth    DateTime?
  gender         String?
  nationality    String?
  phone          String?
  address        String?
  emergencyName  String?
  emergencyPhone String?

  // Qualifications
  qualificationType String? // WASSCE, MATURE, INTERNATIONAL, POSTGRADUATE
  examIndexNo       String?
  examYear          String?
  results           Json? // [{subject, grade}]

  // Review
  aiPrescreen    Json?
  infoRequest    String?
  recommendation Recommendation?
  decisionNote   String?
  submittedAt    DateTime?
  decidedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  choices   ApplicationChoice[]
  documents ApplicationDocument[]
  offer     Offer?
  student   Student?

  @@index([cycleId, status])
  @@index([userId])
}

model ApplicationChoice {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  programmeId   String
  programme     Programme   @relation(fields: [programmeId], references: [id])
  rank          Int // 1, 2, 3

  @@unique([applicationId, rank])
}

enum ApplicationDocKind {
  RESULTS_SLIP
  CERTIFICATE
  TRANSCRIPT
  PHOTO
  ID_DOCUMENT
  OTHER
}

model ApplicationDocument {
  id            String             @id @default(cuid())
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  kind          ApplicationDocKind
  fileName      String
  filePath      String
  mimeType      String
  size          Int
  extracted     Json? // AI-extracted structured data (user-confirmed)
  uploadedAt    DateTime           @default(now())

  @@index([applicationId])
}

model Offer {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id])
  programmeId   String
  programme     Programme   @relation(fields: [programmeId], references: [id])
  issuedAt      DateTime    @default(now())
  expiresAt     DateTime?
  acceptedAt    DateTime?
  declinedAt    DateTime?
  letterCode    String      @unique // public verification code
}

// ─── Students (Phase 2) ───

enum StudentStatus {
  ACTIVE
  DEFERRED
  WITHDRAWN
  DISMISSED
  GRADUATED
}

model Student {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id])
  indexNo             String             @unique
  programmeId         String
  programme           Programme          @relation(fields: [programmeId], references: [id])
  curriculumVersionId String?
  curriculumVersion   CurriculumVersion? @relation(fields: [curriculumVersionId], references: [id])
  entryYearId         String
  entryYear           AcademicYear       @relation(fields: [entryYearId], references: [id])
  applicationId       String?            @unique
  application         Application?       @relation(fields: [applicationId], references: [id])
  status              StudentStatus      @default(ACTIVE)
  admittedAt          DateTime           @default(now())

  statusHistory StudentStatusHistory[]
  registrations Registration[]
  gradeEntries  GradeEntry[]
  results       SemesterResult[]
  invoices      Invoice[]
  bookings      Booking[]
  submissions   Submission[]
  quizAttempts  QuizAttempt[]
  candidature   Candidature?
  evaluations   Evaluation[]

  @@index([programmeId])
}

model StudentStatusHistory {
  id        String        @id @default(cuid())
  studentId String
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  from      StudentStatus
  to        StudentStatus
  reason    String?
  actorId   String?
  at        DateTime      @default(now())

  @@index([studentId])
}

// ─── Curriculum & courses (Phase 3) ───

model Course {
  id           String     @id @default(cuid())
  code         String     @unique // "CPE 101"
  title        String
  credits      Int
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  description  String?

  curriculumCourses CurriculumCourse[]
  offerings         CourseOffering[]
  prerequisites     Prerequisite[]     @relation("course")
  requiredBy        Prerequisite[]     @relation("requires")
}

model Prerequisite {
  courseId   String
  course     Course @relation("course", fields: [courseId], references: [id], onDelete: Cascade)
  requiresId String
  requires   Course @relation("requires", fields: [requiresId], references: [id], onDelete: Cascade)

  @@id([courseId, requiresId])
}

model CurriculumVersion {
  id          String    @id @default(cuid())
  programmeId String
  programme   Programme @relation(fields: [programmeId], references: [id])
  name        String // "2026 entry"
  minCredits  Int       @default(15)
  maxCredits  Int       @default(21)

  courses  CurriculumCourse[]
  students Student[]

  @@unique([programmeId, name])
}

enum CourseType {
  CORE
  ELECTIVE
}

model CurriculumCourse {
  id             String            @id @default(cuid())
  curriculumId   String
  curriculum     CurriculumVersion @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  courseId       String
  course         Course            @relation(fields: [courseId], references: [id])
  semesterNumber Int // 1..N over the whole programme
  type           CourseType        @default(CORE)

  @@unique([curriculumId, courseId])
}

// ─── Registration (Phase 3) ───

model CourseOffering {
  id         String   @id @default(cuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id])
  semesterId String
  semester   Semester @relation(fields: [semesterId], references: [id])
  capacity   Int?

  lecturers           OfferingLecturer[]
  registrationCourses RegistrationCourse[]
  gradeSheet          GradeSheet?
  materials           Material[]
  assignments         Assignment[]
  quizzes             Quiz[]
  sessions            TimetableSession[]
  evaluations         Evaluation[]

  @@unique([courseId, semesterId])
}

model OfferingLecturer {
  offeringId  String
  offering    CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  staffUserId String
  staffUser   User           @relation(fields: [staffUserId], references: [id])

  @@id([offeringId, staffUserId])
}

enum RegistrationStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

model Registration {
  id           String             @id @default(cuid())
  studentId    String
  student      Student            @relation(fields: [studentId], references: [id])
  semesterId   String
  semester     Semester           @relation(fields: [semesterId], references: [id])
  status       RegistrationStatus @default(DRAFT)
  submittedAt  DateTime?
  approvedAt   DateTime?
  approvedById String?

  courses RegistrationCourse[]

  @@unique([studentId, semesterId])
}

model RegistrationCourse {
  id             String         @id @default(cuid())
  registrationId String
  registration   Registration   @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  offeringId     String
  offering       CourseOffering @relation(fields: [offeringId], references: [id])
  isRetake       Boolean        @default(false)

  @@unique([registrationId, offeringId])
}

// ─── Examinations & results (Phase 4) ───

enum GradeSheetStatus {
  DRAFT
  SUBMITTED
  HOD_APPROVED
  DEAN_APPROVED
  VALIDATED
  PUBLISHED
  RETURNED
}

model GradeSheet {
  id          String           @id @default(cuid())
  offeringId  String           @unique
  offering    CourseOffering   @relation(fields: [offeringId], references: [id])
  status      GradeSheetStatus @default(DRAFT)
  caWeight    Int              @default(30)
  examWeight  Int              @default(70)
  submittedAt DateTime?
  publishedAt DateTime?

  entries   GradeEntry[]
  approvals GradeSheetApproval[]
}

model GradeEntry {
  id           String     @id @default(cuid())
  gradeSheetId String
  gradeSheet   GradeSheet @relation(fields: [gradeSheetId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  caScore      Float?
  examScore    Float?
  total        Float?
  grade        String? // A, B+, ... F
  gradePoint   Float?

  @@unique([gradeSheetId, studentId])
}

enum ApprovalStage {
  HOD
  DEAN
  EXAMS_OFFICE
  REGISTRAR
}

enum ApprovalDecision {
  APPROVED
  RETURNED
}

model GradeSheetApproval {
  id           String           @id @default(cuid())
  gradeSheetId String
  gradeSheet   GradeSheet       @relation(fields: [gradeSheetId], references: [id], onDelete: Cascade)
  stage        ApprovalStage
  decision     ApprovalDecision
  note         String?
  actorId      String
  at           DateTime         @default(now())

  @@index([gradeSheetId])
}

enum AcademicStanding {
  GOOD
  PROBATION
  WITHDRAWN
}

model SemesterResult {
  id                String           @id @default(cuid())
  studentId         String
  student           Student          @relation(fields: [studentId], references: [id])
  semesterId        String
  semester          Semester         @relation(fields: [semesterId], references: [id])
  creditsTaken      Int
  creditsEarned     Int
  semesterAverage   Float // credit-weighted average (CWA regime)
  cumulativeAverage Float
  standing          AcademicStanding @default(GOOD)
  publishedAt       DateTime         @default(now())

  @@unique([studentId, semesterId])
}

// ─── Fees & finance (Phase 5) ───

model FeeSchedule {
  id             String         @id @default(cuid())
  academicYearId String
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])
  level          ProgrammeLevel
  name           String

  items FeeItem[]

  @@unique([academicYearId, level])
}

model FeeItem {
  id         String      @id @default(cuid())
  scheduleId String
  schedule   FeeSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  name       String
  amount     Int // pesewas per semester
}

enum InvoiceKind {
  APPLICATION
  ACCEPTANCE
  TUITION
  HOSTEL
  DOCUMENT
  RESIT
  FINE
  SHORT_COURSE
  OTHER
}

enum InvoiceStatus {
  PENDING
  PART_PAID
  PAID
  VOID
}

model Invoice {
  id         String        @id @default(cuid())
  invoiceNo  String        @unique
  kind       InvoiceKind
  status     InvoiceStatus @default(PENDING)
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  studentId  String?
  student    Student?      @relation(fields: [studentId], references: [id])
  semesterId String?
  semester   Semester?     @relation(fields: [semesterId], references: [id])
  total      Int
  paid       Int           @default(0)
  dueAt      DateTime?
  meta       Json?
  createdAt  DateTime      @default(now())

  lines    InvoiceLine[]
  payments Payment[]

  @@index([userId])
  @@index([studentId, kind])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  amount      Int
}

enum PaymentChannel {
  MOCK
  PAYSTACK
  TELLER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

model Payment {
  id        String         @id @default(cuid())
  invoiceId String
  invoice   Invoice        @relation(fields: [invoiceId], references: [id])
  channel   PaymentChannel
  reference String         @unique
  amount    Int
  status    PaymentStatus  @default(PENDING)
  paidAt    DateTime?
  meta      Json?
  createdAt DateTime       @default(now())

  @@index([invoiceId])
}

// ─── Issued documents & verification (Phases 1, 4, 8) ───

enum IssuedDocType {
  ADMISSION_LETTER
  RECEIPT
  TRANSCRIPT
  PROOF_OF_REGISTRATION
  ALLOCATION_SLIP
  ATTESTATION
}

model IssuedDocument {
  id        String        @id @default(cuid())
  type      IssuedDocType
  code      String        @unique // public verification code
  title     String
  userId    String?
  payload   Json // everything needed to re-render and verify
  createdAt DateTime      @default(now())

  @@index([userId])
}

// ─── Accommodation (Phase 6) ───

enum HostelGender {
