// ─── E-learning (Phase 7) ───

enum MaterialKind {
  FILE
  LINK
  TEXT
}

model Material {
  id          String         @id @default(cuid())
  offeringId  String
  offering    CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  title       String
  kind        MaterialKind
  content     String? // link URL or text body
  filePath    String?
  week        Int?
  createdById String?
  createdAt   DateTime       @default(now())
}

model Assignment {
  id           String         @id @default(cuid())
  offeringId   String
  offering     CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  title        String
  instructions String
  dueAt        DateTime
  maxScore     Int            @default(100)
  createdAt    DateTime       @default(now())

  submissions Submission[]
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])
  text         String?
  filePath     String?
  submittedAt  DateTime   @default(now())
  score        Float?
  feedback     String?
  gradedAt     DateTime?
  aiSuggestion Json? // {score, rationale} — advisory until lecturer approves

  @@unique([assignmentId, studentId])
}

model Quiz {
  id          String         @id @default(cuid())
  offeringId  String
  offering    CourseOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  title       String
  durationMin Int?
  opensAt     DateTime?
  closesAt    DateTime?
  published   Boolean        @default(false)

  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id           String @id @default(cuid())
  quizId       String
  quiz         Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  ord          Int
  prompt       String
  options      Json // string[]
  correctIndex Int
  points       Int    @default(1)
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  startedAt   DateTime  @default(now())
  submittedAt DateTime?
  answers     Json? // number[] by question ord
  score       Float?

  @@unique([quizId, studentId])
}

