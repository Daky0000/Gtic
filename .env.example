# --- Database ---
DATABASE_URL="postgresql://campuscore:campuscore_dev@localhost:5433/campuscore"

# --- Auth ---
BETTER_AUTH_SECRET="replace-with-a-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Payments (Paystack: cards + MTN/Telecel/AT mobile money, GHS) ---
# Leave empty to run on the instant mock channel (no external calls, demo mode).
# With a key set, online payments redirect to Paystack hosted checkout; also
# point a Paystack webhook at <NEXT_PUBLIC_APP_URL>/api/payments/paystack/webhook.
# Note: a key saved in the developer console (/admin/settings) overrides this.
PAYSTACK_SECRET_KEY=""

# --- AI (Claude) ---
# Leave ANTHROPIC_API_KEY empty to run on the deterministic mock provider (no cost, offline).
ANTHROPIC_API_KEY=""
# auto = anthropic when key present, otherwise mock. Or force: "anthropic" | "mock"
AI_PROVIDER="auto"
