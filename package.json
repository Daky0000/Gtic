{
  "name": "campuscore",
  "version": "0.1.0",
  "private": true,
  "description": "CampusCore — AI-cored University Management System",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "prisma migrate deploy && tsx prisma/create-demo-users.ts && next start",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "admin:create": "tsx prisma/create-admin.ts",
    "users:demo": "tsx prisma/create-demo-users.ts",
    "db:studio": "prisma studio",
    "docs:plan": "node docs/generate-plan-docx.mjs",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@prisma/client": "^6.19.3",
    "better-auth": "^1.6.23",
    "docx": "^9.7.1",
    "next": "^15.5.20",
    "prisma": "^6.19.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.2",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3"
  }
}
